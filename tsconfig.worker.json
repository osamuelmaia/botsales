{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".worker-dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["workers/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "app", "components"]
}
