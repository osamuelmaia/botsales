generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum PersonType {
  INDIVIDUAL
  COMPANY
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
}

enum BillingType {
  MONTHLY
  ANNUAL
}

enum UserRole {
  USER
  ADMIN
}

enum FlowNodeType {
  TRIGGER_START
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  TYPING
  BUTTON
  DELAY
  SMART_DELAY
  PAYMENT
  REMARKETING_START
  KICK_MEMBER
  GRANT_ACCESS
}

enum SaleStatus {
  PENDING
  APPROVED
  REFUSED
  REFUNDED
  CHARGEBACK
}

enum SubscriptionStatus {
  ACTIVE
  REMARKETING
  KICKED
  CANCELLED
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountType {
  CHECKING
  SAVINGS
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id                 String      @id @default(cuid())
  name               String
  email              String      @unique
  passwordHash       String
  emailVerified      DateTime?
  registrationStep   Int         @default(1)
  personType         PersonType?
  document           String?
  phone              String?
  zipCode            String?
  street             String?
  number             String?
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  platformFeePercent Decimal     @default(5.99)
  platformFeeCents   Int         @default(100)
  withdrawalDays     Int         @default(30)
  role               UserRole    @default(USER)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  bots         Bot[]
  products     Product[]
  sales        Sale[]
  withdrawals  Withdrawal[]
  bankAccounts BankAccount[]
  media        BotMedia[]
}

model Bot {
  id                       String    @id @default(cuid())
  userId                   String
  name                     String
  tokenEncrypted           String
  channelId                String?
  isActive                 Boolean   @default(false)
  gracePeriodDays          Int       @default(3)
  remarketingFlow          Json?
  channelPermissionError   String?
  channelPermissionErrorAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  botProducts   BotProduct[]
  flowNodes     FlowNode[]
  flowEdges     FlowEdge[]
  leads         Lead[]
  subscriptions Subscription[]
  pendingKicks  PendingKick[]

  @@index([userId])
}

model Product {
  id             String          @id @default(cuid())
  userId         String
  name           String
  description    String?
  priceInCents   Int
  paymentMethods PaymentMethod[]
  isRecurring    Boolean         @default(false)
  billingType    BillingType?
  billingCycles  Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  botProducts   BotProduct[]
  sales         Sale[]
  subscriptions Subscription[]

  @@index([userId])
}

model BotProduct {
  botId     String
  productId String
  position  Int    @default(0)

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([botId, productId])
}

model FlowNode {
  id    String       @id @default(cuid())
  botId String
  type  FlowNodeType
  posX  Float
  posY  Float
  data  Json

  bot         Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)
  sourceEdges FlowEdge[] @relation("SourceNode")
  targetEdges FlowEdge[] @relation("TargetNode")

  @@index([botId])
}

model FlowEdge {
  id           String  @id @default(cuid())
  botId        String
  sourceNodeId String
  targetNodeId String
  sourceHandle String?
  label        String?

  bot        Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  sourceNode FlowNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode FlowNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([botId])
}

model Lead {
  id         String   @id @default(cuid())
  botId      String
  telegramId String
  name       String?
  username   String?
  phone      String?
  email      String?
  createdAt  DateTime @default(now())

  bot           Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)
  sales         Sale[]
  subscriptions Subscription[]

  // Customer portal access
  portalPasswordHash String?

  @@unique([botId, telegramId])
  @@index([botId])
  @@index([email])
}

model Sale {
  id               String        @id @default(cuid())
  userId           String
  productId        String
  leadId           String?
  // Telegram context — set when sale originates from a bot flow
  botId            String?       // which bot generated this payment
  tgChatId         String?       // Telegram chatId (as string) of the buyer
  paymentNodeId    String?       // FlowNode.id of the PAYMENT node that triggered this sale
  paymentMethod    PaymentMethod
  status           SaleStatus    @default(PENDING)
  grossAmountCents Int
  feeAmountCents   Int
  netAmountCents   Int
  gatewayId           String?
  gatewayStatus       String?
  paidAt              DateTime?
  availableAt         DateTime?
  refundedAt          DateTime?
  pendingFlowFiredAt  DateTime?   // set when the "pending" flow branch is triggered
  createdAt           DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  lead    Lead?   @relation(fields: [leadId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  bankAccountId String
  amountCents   Int
  status        WithdrawalStatus @default(REQUESTED)
  adminNote     String?          // rejection reason or admin notes
  reviewedBy    String?          // admin userId who approved/rejected
  requestedAt   DateTime         @default(now())
  reviewedAt    DateTime?        // when admin acted on this
  processedAt   DateTime?        // when payment was actually sent

  user        User        @relation(fields: [userId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
}

model BotMedia {
  id           String   @id @default(cuid())
  userId       String
  key          String   @unique
  url          String
  mimeType     String
  sizeBytes    Int
  originalName String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BankAccount {
  id          String      @id @default(cuid())
  userId      String
  bankCode    String
  agency      String
  account     String
  accountType AccountType
  holderName  String
  document    String
  pixKey      String?
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]

  @@index([userId])
}

model Subscription {
  id               String             @id @default(cuid())
  botId            String
  leadId           String
  productId        String
  groupTgChatId    String             // Telegram group ID (from Bot.channelId at creation time)
  tgUserId         String             // Telegram user ID of subscriber
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime
  gatewayChargeId  String?            // Latest Asaas charge ID
  remarketingStart DateTime?          // When remarketing started
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([botId])
  @@index([leadId])
  @@index([status])
  @@index([tgUserId])
}

model PendingKick {
  id             String   @id @default(cuid())
  botId          String
  subscriptionId String
  tgUserId       String
  groupChatId    String
  failedAt       DateTime @default(now())
  errorMessage   String?

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
}
